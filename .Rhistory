# ---- 8. Diskussion ------------------------------------------
# Degree (links):
#   Fast das gesamte Netz hat ähnlich hohe Degree-Werte (orange/gelb).
#   Leicht höhere Werte im Mittelland zwischen Basel, Zürich und Bern,
#   wo sich viele Routen kreuzen und Knoten mehr direkte Verbindungen haben.
#   Periphere Gebiete wie das Tessin (Chiasso) oder Graubünden (Chur, Mals)
#   zeigen tiefere Werte, weil das Netz dort dünner ist.
# Closeness (Mitte):
#   Der räumliche Gradient ist hier am deutlichsten sichtbar: das Mittelland
#   leuchtet hell (hohe Closeness), die Peripherie bleibt dunkel.
#   Das Zentrum Zürich/Bern/Basel hat die höchsten Werte – von dort sind
#   alle anderen Knoten über kurze Gesamtdistanzen erreichbar.
#   Das Tessin, Genf und Graubünden sind peripher und schlecht angebunden,
#   was der Alpentopografie entspricht: lange Umwege durch Täler erhöhen
#   die Netzwerkdistanzen stark.
# Betweenness (rechts):
#   Dieser Plot ist der interessanteste: fast das gesamte Netz ist dunkel
#   (nahe 0), aber wenige Kanten leuchten hell auf. Diese hellen Kanten
#   sind die kritischen Flaschenhälse des Netzes – Verbindungen, durch die
#   besonders viele kürzeste Pfade verlaufen. Man erkennt deutlich die
#   Hauptachsen: das Rhonetal (Richtung Genf), das Rheintal (Richtung
#   Mals/Chur) und die Ost-West-Achse durch das Mittelland. Würde eine
#   dieser Kanten wegfallen, wäre das Netz stark fragmentiert.
# Fazit:
#   Die drei Masse messen unterschiedliche Aspekte von Zentralität.
#   Degree zeigt lokale Vernetzung, Closeness zeigt die geografische Lage
#   im Gesamtnetz, und Betweenness identifiziert infrastrukturell kritische
#   Verbindungen – besonders relevant für Netzplanung und Resilienzanalyse.
# ============================================================
# Routing – Swiss Cycle Network (Veloland)
# Spatial Data Science – Network Analysis I
# Daten: ASTRA/FEDRO  |  CRS: EPSG:2056 (CH1903+ LV95)
# ============================================================
# ---- 0. Pakete laden ----------------------------------------
library(sf)
library(sfnetworks)
library(tidygraph)
library(dplyr)
library(ggplot2)
# ---- 1. Daten laden & Netzwerk erstellen --------------------
pfad <- "C:/Users/Lejlum/network_analysis"
veloland_lines <- st_read(file.path(pfad, "veloland.gpkg"))
orte           <- st_read(file.path(pfad, "locations.gpkg"))
# Ungerichtetes Netzwerk (gleich wie in der Centrality-Aufgabe)
net <- as_sfnetwork(veloland_lines, directed = FALSE)
# ---- 2. Origin & Destination definieren ---------------------
# Ersten Ort als Startpunkt wählen (Bern, Index 1)
# orte$Ortschaft zeigt alle verfügbaren Städte
print(orte$Ortschaft)   # Übersicht: welche Städte vorhanden sind
origin      <- orte[1, ]   # erster Ort = Startpunkt
destination <- orte[-1, ]  # alle anderen Orte = Zielpunkte
# ---- 3. Kürzeste Pfade berechnen ----------------------------
# st_network_paths() berechnet für jeden Zielpunkt den kürzesten Pfad
# vom Startpunkt, gewichtet nach Kantenlänge.
paths <- st_network_paths(
net,
from    = origin,
to      = destination,
weights = "length"
)
# Ergebnis: data.frame mit zwei Spalten
# - node_paths: Knotenindizes des Pfades
# - edge_paths: Kantenindizes des Pfades (brauchen wir für die Geometrie)
print(paths)
# ---- 4. sf-Objekte pro Pfad erstellen -----------------------
# Kanten des Netzwerks als sf extrahieren
net_edges <- net %>% activate(edges) %>% st_as_sf()
# Für jeden Pfad die entsprechenden Kanten herausfiltern
# und zu einer Linie zusammenfassen
path_lines <- lapply(seq_len(nrow(paths)), function(i) {
edge_ids <- paths$edge_paths[[i]]      # Kantenindizes dieses Pfades
segment  <- net_edges[edge_ids, ]      # zugehörige Linien
segment$destination <- destination$Ortschaft[i]  # Zielname anhängen
segment
})
# Alle Pfade zu einem sf-Objekt zusammenführen
all_paths <- do.call(rbind, path_lines)
# ---- 5. Visualisierung ---------------------------------------
ggplot() +
# Gesamtes Netzwerk als Hintergrund (grau, dünn)
geom_sf(data = net_edges,
color = "grey80", linewidth = 0.2) +
# Berechnete Pfade, eingefärbt nach Zielort
geom_sf(data = all_paths,
aes(color = destination), linewidth = 0.8) +
# Zielpunkte
geom_sf(data = destination,
shape = 21, fill = "white", color = "black",
size = 2.5, stroke = 0.7) +
# Startpunkt (hervorgehoben)
geom_sf(data = origin,
shape = 23, fill = "red", color = "black",
size = 3.5, stroke = 0.7) +
# Beschriftungen
geom_sf_text(data = destination,
aes(label = Ortschaft),
size = 2.6, fontface = "bold",
vjust = -0.9, color = "black") +
geom_sf_text(data = origin,
aes(label = Ortschaft),
size = 2.6, fontface = "bold",
vjust = -0.9, color = "red") +
scale_color_brewer(palette = "Dark2", name = "Ziel") +
labs(
title   = paste0("Shortest paths from ", origin$Ortschaft,
" to all other locations"),
caption = "Data: ASTRA/FEDRO  |  CRS: EPSG:2056  |  Weights: edge length [m]"
) +
theme_void(base_size = 10) +
theme(
plot.title   = element_text(size = 12, face = "bold",
hjust = 0.5, margin = margin(b = 6)),
plot.caption = element_text(size = 7.5, color = "grey50", hjust = 1),
legend.position = "right"
)
# Speichern
ggsave(file.path(pfad, "routing_veloland.png"),
width = 12, height = 7, dpi = 200, bg = "white")
message("Gespeichert: ", file.path(pfad, "routing_veloland.png"))
