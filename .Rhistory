veloland_lines <- st_read(file.path(pfad, "veloland.gpkg"))
# Spalten: length (Kantenlänge in Metern), geometry (LineString)
# CRS: EPSG:2056 – bereits metrisch, keine Transformation nötig
orte <- st_read(file.path(pfad, "locations.gpkg"))
# Spalten: Ortschaft, geometry (8 Schweizer Städte als Punkte)
# ---- 2. sf --> sfnetwork (ungerichtet) -----------------------
net <- as_sfnetwork(veloland_lines, directed = FALSE)
# ---- 3. Zentralitäten berechnen -----------------------------
# Knoten aktivieren und drei Masse als neue Spalten hinzufügen.
# Gewicht = Kantenlänge aus der Spalte "length" (bereits vorhanden)
net_c <- net %>%
activate(nodes) %>%
mutate(
degree      = centrality_degree(),
closeness   = centrality_closeness(weights = length),
betweenness = centrality_betweenness(weights = length)
)
# ---- 4. Zurück zu sf-Objekten --------------------------------
veloland_nodes <- net_c %>% activate(nodes) %>% st_as_sf()
veloland_edges <- net_c %>% activate(edges) %>% st_as_sf()
# ---- 5. Zentralitätswerte auf Kanten übertragen -------------
veloland_edges_c <- aggregate(veloland_nodes, veloland_edges, FUN = "mean")
# ---- 6. Normalisierung auf [0,1] ----------------------------
# Alle drei Masse auf dieselbe Skala bringen -> direkt vergleichbar.
# scales::rescale() macht aus jedem Wert einen Anteil zwischen 0 und 1.
veloland_edges_c <- veloland_edges_c %>%
mutate(
degree_norm      = scales::rescale(degree),
closeness_norm   = scales::rescale(closeness),
betweenness_norm = scales::rescale(betweenness)
)
# ---- 7. Visualisierung ---------------------------------------
make_map <- function(data, fill_var, title, orte) {
ggplot() +
geom_sf(data = data, aes(color = .data[[fill_var]]), linewidth = 0.3) +
scale_color_viridis_c(
option = "plasma",
name   = "norm. Wert\n[0 – 1]",
limits = c(0, 1),                          # gleiche Skala für alle
guide  = guide_colorbar(barwidth = 0.5, barheight = 5)
) +
geom_sf(data = orte, shape = 21, fill = "white", color = "black",
size = 1.8, stroke = 0.5) +
geom_sf_text(data = orte, aes(label = Ortschaft),
size = 2.4, fontface = "bold", vjust = -0.8,
color = "black") +
labs(title = title) +
theme_void(base_size = 9) +
theme(
plot.title      = element_text(size = 10, face = "bold",
hjust = 0.5, margin = margin(b = 4)),
legend.position = "right"
)
}
p_degree      <- make_map(veloland_edges_c, "degree_norm",      "degree",      orte)
p_closeness   <- make_map(veloland_edges_c, "closeness_norm",   "closeness",   orte)
p_betweenness <- make_map(veloland_edges_c, "betweenness_norm", "betweenness", orte)
(p_degree | p_closeness | p_betweenness) +
plot_annotation(
title   = "Centrality measures – Swiss cycle network (Veloland)",
caption = "Data: ASTRA/FEDRO  |  CRS: EPSG:2056  |  Weights: edge length [m]",
theme   = theme(
plot.title   = element_text(size = 12, face = "bold", hjust = 0.5),  # <-- zentriert
plot.caption = element_text(size = 7.5, color = "grey50", hjust = 1)
)
)
ggsave(file.path(pfad, "centrality_veloland.png"),
width = 15, height = 5.5, dpi = 200, bg = "white")
# ---- 8. Diskussion ------------------------------------------
# degree:
#   Hohe Werte im dichten Strassennetz des Mittellands (viele Kreuzungen).
#   Alpine Regionen haben wenige Knoten pro Fläche -> tiefer Degree.
#
# closeness:
#   Hoch im geografischen Zentrum (Bern/Luzern-Raum): von dort sind
#   alle anderen Knoten über kurze Gesamtdistanzen erreichbar.
#   Periphere Regionen (Wallis, Graubünden) haben tiefere Werte, da
#   das Netz durch Alpentäler eingeschnürt ist.
#
# betweenness:
#   Wenige kritische Kanten haben extrem hohe Werte: Alpendurchquerungen
#   (Rhonetal, Rheintal, Gotthard-Achse). Fast alle Routen zwischen
#   Nord- und Südschweiz führen durch diese Flaschenhälse.
#   -> Diese Kanten sind infrastrukturell besonders wichtig.
# ============================================================
# Centrality Analysis – Swiss Cycle Network (Veloland)
# Spatial Data Science – Network Analysis I
# Daten: ASTRA/FEDRO  |  CRS: EPSG:2056 (CH1903+ LV95)
# ============================================================
# ---- 0. Pakete laden ----------------------------------------
library(sf)          # Geodaten lesen
library(sfnetworks)  # sf -> Netzwerk
library(tidygraph)   # activate(), centrality_*()
library(dplyr)       # mutate(), %>%
library(ggplot2)     # Visualisierung
library(patchwork)   # Plots kombinieren
library(scales)
# ---- 1. Daten laden -----------------------------------------
# Pfad zum Projektordner (Backslashes durch Schrägstriche ersetzen)
pfad <- "C:/Users/Lejlum/network_analysis"
veloland_lines <- st_read(file.path(pfad, "veloland.gpkg"))
# Spalten: length (Kantenlänge in Metern), geometry (LineString)
# CRS: EPSG:2056 – bereits metrisch, keine Transformation nötig
orte <- st_read(file.path(pfad, "locations.gpkg"))
# Spalten: Ortschaft, geometry (8 Schweizer Städte als Punkte)
# ---- 2. sf --> sfnetwork (ungerichtet) -----------------------
net <- as_sfnetwork(veloland_lines, directed = FALSE)
# ---- 3. Zentralitäten berechnen -----------------------------
# Knoten aktivieren und drei Masse als neue Spalten hinzufügen.
# Gewicht = Kantenlänge aus der Spalte "length" (bereits vorhanden)
net_c <- net %>%
activate(nodes) %>%
mutate(
degree      = centrality_degree(),
closeness   = centrality_closeness(weights = length),
betweenness = centrality_betweenness(weights = length)
)
# ---- 4. Zurück zu sf-Objekten --------------------------------
veloland_nodes <- net_c %>% activate(nodes) %>% st_as_sf()
veloland_edges <- net_c %>% activate(edges) %>% st_as_sf()
# ---- 5. Zentralitätswerte auf Kanten übertragen -------------
veloland_edges_c <- aggregate(veloland_nodes, veloland_edges, FUN = "mean")
# ---- 6. Normalisierung auf [0,1] ----------------------------
# Alle drei Masse auf dieselbe Skala bringen -> direkt vergleichbar.
# scales::rescale() macht aus jedem Wert einen Anteil zwischen 0 und 1.
veloland_edges_c <- veloland_edges_c %>%
mutate(
degree_norm      = scales::rescale(degree),
closeness_norm   = scales::rescale(closeness),
betweenness_norm = scales::rescale(betweenness)
)
# ---- 7. Visualisierung ---------------------------------------
make_map <- function(data, fill_var, title, orte) {
ggplot() +
geom_sf(data = data, aes(color = .data[[fill_var]]), linewidth = 0.3) +
